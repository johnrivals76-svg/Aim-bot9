-- Local Player
local LocalPlayer = Players.LocalPlayer
local Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
local HumanoidRootPart = Character:WaitForChild("HumanoidRootPart")
local Camera = Workspace.CurrentCamera
local PlayerGui = LocalPlayer.PlayerGui

-- Get safe area insets to avoid notches/status bars
local TopInset, BottomInset = GuiService:GetGuiInset()

-- Settings
local Settings = {
    AimLockEnabled = true,
    AimLockActive = false, -- Controlled by dedicated touch button
    RainbowHighlightEnabled = true,
    FOVColor = Color3.new(1, 0, 0), -- Red
    FOVRadius = 15,
    SmoothAim = 100, -- 100% = instant alignment
    Prediction = 100 -- 100% = full movement prediction
}

-- ------------------------------
-- Targeting Logic
-- ------------------------------
local function GetClosestTarget()
    local ClosestDistance = math.huge
    local TargetHead = nil

    for _, Player in pairs(Players:GetPlayers()) do
        if Player ~= LocalPlayer and Player.Character then
            local TargetCharacter = Player.Character
            local Head = TargetCharacter:FindFirstChild("Head")
            local RootPart = TargetCharacter:FindFirstChild("HumanoidRootPart")
            
            -- Team check (don't lock onto teammates)
            if Player.Team == LocalPlayer.Team then
                continue
            end

            if Head and RootPart then
                local Distance = (RootPart.Position - HumanoidRootPart.Position).Magnitude
                local Direction = (RootPart.Position - Camera.CFrame.Position).Unit
                local RaycastParams = RaycastParams.new()
                RaycastParams.FilterDescendantsInstances = {Character}
                RaycastParams.FilterType = Enum.RaycastFilterType.Exclude
                
                local RaycastResult = Workspace:Raycast(Camera.CFrame.Position, Direction * Distance, RaycastParams)

                -- Check if target is within FOV and visible
                if Distance < ClosestDistance and Distance <= Settings.FOVRadius and (not RaycastResult or RaycastResult.Instance:IsDescendantOf(TargetCharacter)) then
                    ClosestDistance = Distance
                    TargetHead = Head
                end
            end
        end
    end

    return TargetHead
end

-- ------------------------------
-- Prediction Logic
-- ------------------------------
local function CalculatePredictedPosition(HeadPart)
    local CharacterModel = HeadPart.Parent
    local RootPart = CharacterModel:FindFirstChild("HumanoidRootPart")
    if not RootPart then return HeadPart.Position end

    -- Get movement velocity
    local Velocity = RootPart.Velocity
    -- 100% prediction = apply full velocity
    local PredictedPosition = HeadPart.Position + (Velocity * RunService.Heartbeat:Wait() * (Settings.Prediction / 100))
    return PredictedPosition
end

-- ------------------------------
-- Rainbow Highlight Logic
-- ------------------------------
local ActiveHighlights = {}
local Hue = 0

local function UpdateHighlights(TargetHead)
    -- Clear old highlights
    for Part, HighlightObj in pairs(ActiveHighlights) do
        HighlightObj:Destroy()
    end
    table.clear(ActiveHighlights)

    if Settings.RainbowHighlightEnabled and TargetHead then
        Hue = (Hue + 0.005) % 1 -- Cycle hue value
        local RainbowColor = Color3.fromHSV(Hue, 1, 1)

        local Highlight = Instance.new("Highlight")
        Highlight.Parent = TargetHead
        Highlight.FillColor = RainbowColor
        Highlight.OutlineColor = RainbowColor
        Highlight.FillTransparency = 0.5
        Highlight.OutlineTransparency = 0
        Highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop

        ActiveHighlights[TargetHead] = Highlight
    end
end

