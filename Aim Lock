-- ------------------------------
-- ✅ UPDATED MAIN LOOP (Mobile Optimized)
-- ------------------------------
RunService.RenderStepped:Connect(function(deltaTime)
    -- Only run if features are enabled and activation is active
    if not Settings.AimLockEnabled or not Settings.AimLockActive then return end

    local TargetHead = GetClosestTarget()
    if TargetHead then
        -- Calculate where the target will be
        local PredictedPos = CalculatePredictedPosition(TargetHead)
        local AimDirection = (PredictedPos - Camera.CFrame.Position).Unit

        -- Smooth Aim Logic (100% = instant, <100% = gradual movement)
        if Settings.SmoothAim == 100 then
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, Camera.CFrame.Position + AimDirection)
        else
            local TargetCFrame = CFrame.new(Camera.CFrame.Position, Camera.CFrame.Position + AimDirection)
            -- Use deltaTime for frame-rate independent smoothing (consistent on all mobile devices)
            local SmoothSpeed = (Settings.SmoothAim / 100) * deltaTime * 10
            Camera.CFrame = Camera.CFrame:Lerp(TargetCFrame, SmoothSpeed)
        end

        -- Update target highlight
        UpdateHighlights(TargetHead)
    end
end)

